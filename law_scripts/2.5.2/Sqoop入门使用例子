//1.在数据库test中有一个用户表user，有两个字段id，name，分别为int类型和字符类型。将user表的数据导入HDFS
sqoop import --connect jdbc:mysql://node1:3306/test --username root --password root --table user --target-dir /user/root/test/ -m 1 --driver com.mysql.jdbc.Driver

//2.将user表的数据导入Hive
sqoop import --connect jdbc:mysql://node1:3306/test --username root --password root --table user --hive-import --hive-database test --hive-table user -m 1 --delete-target-dir --driver com.mysql.jdbc.Driver

//3.sqoop import增量导入示例
sqoop import --connect jdbc:mysql://node1:3306/test --username root --password root --table user -m 1 --hive-import --hive-database test --hive-table user --incremental append --check-column id --last-value 0 --driver com.mysql.jdbc.Driver

//4.sqoop job应用实例
sqoop job --create "myjob" -- import --connect jdbc:mysql://node1:3306/test --username root --password root --table user --m 1 --hive-import --hive-database test --hive-table user --incremental append --check-column id --last-value 0 --driver com.mysql.jdbc.Driver