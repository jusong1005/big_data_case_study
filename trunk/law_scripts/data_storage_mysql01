将law的SQL文件中的数据，导入到MYSQL中。

第一步：创建数据库
//检查mysql是否含有law_init数据库
drop database if exists law_init;
//创建数据库并进入law_init数据库
create database law_init;
use law_init;

第二步：创建表lawtime_all
create table lawtime_all(
realIP int,
realAreacode int,
userAgent varchar(100),
userOS varchar(20),
userID double,
clientID double,
timestamps varchar(20),
timestamp_format varchar(30),
pagePath varchar(200),
ymd int,
fullURL varchar(200),
fullURLID int,
hostname varchar(100),
pageTitle varchar(50),
pageTitleCategoryId int,
pageTitleCategoryName varchar(50),
pageTitleKw varchar(50),
fullReferrrer varchar(100),
FullReferrerURL varchar(100),
organicKeyword varchar(100),
source varchar(100)
);

第三步：导入SQL文件的数据到lawtime_all表。导入数据到MYSQL表的Shell脚本。
1）导入数据到lawtime_all的Shell脚本import.sh，如下；
input=$1 #文件所在路径
db=$2 #数据库名称
start_time=$(date +%Y-%m-%d-%H:%M:%S)
echo "start time : $start_time"
start_time=$(date +%s)
for i in `ls $input`
do
echo "import $i file , time : $(date +%Y-%m-%d-%H:%M:%S)"
mysql -uroot -proot -e "use ${db};set names utf8;source ${input}/$i;"
done
end_time=$(date +%Y-%m-%d-%H:%M:%S)
echo "end time : $end_time"
end_time=$(date +%s)
cost_time=$(($end_time - $start_time))
echo " cost time: $cost_time seconds"

2）在脚本所在文件夹通过命令“./import.sh /data/law_data_init law_init”运行脚本