val df = sqlContext.read.table("law.law_visit_log_all_")

val user_index = df.select("userid").distinct.rdd.map(x => x.getString(0)).zipWithIndex.map(x => (x._1,x._2.toInt))

val user_string = df.select("userid","ymd").distinct.rdd.map(row => (row.getString(0),row.getString(1)))

val result = user_string.leftOuterJoin(user_index).map(x => (x._2._1,x._2._2.get))

result.cache
 case class A(ymd:String,userid:Int)
val newDf = result.map(x => A(x._1,x._2)).toDF
val  ymds = newDf.select("ymd").distinct.orderBy("ymd").collect().map(row => row.getString(0))
val data =newDf.groupBy("ymd").agg(collect_set("userid") as "userid_set")
data.cache
val allusers = Array.fill(result.count.toInt)(false)
for(ymd <- ymds.tail){
	val ids= data.filter("ymd = '"+ymd+"'").collect.map(row => row.getSeq[Int](1)).apply(0)
	val first = allusers.filter(x => x).length
	for(id <- ids) allusers(id)=true
	val second = allusers.filter(x => x).length
	println(ymd+":" + (second - first))
}



